__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# --- Build artifacts (packaged node from package.ps1) ---
*.zip

# --- Editor / assistant workspace ---
.claude/
.vscode/
.idea/
*.code-workspace

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini
